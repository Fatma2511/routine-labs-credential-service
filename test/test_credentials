"""
Tests for the Routine Labs Credential Storage Service.
Run: pytest tests/ -v
"""
import os
os.environ["DATABASE_URL"] = "sqlite:///:memory:"

from cryptography.fernet import Fernet
os.environ["ENCRYPTION_KEY"] = Fernet.generate_key().decode()

from fastapi.testclient import TestClient
from sqlalchemy import create_engine
from sqlalchemy.orm import sessionmaker
from unittest.mock import patch
from sqlalchemy.exc import SQLAlchemyError

from src.main import app
from src.database import Base, get_db

test_engine = create_engine("sqlite:///:memory:", connect_args={"check_same_thread": False})
TestSession = sessionmaker(autocommit=False, autoflush=False, bind=test_engine)
Base.metadata.create_all(bind=test_engine)


def override_get_db():
    db = TestSession()
    try:
        yield db
    finally:
        db.close()


app.dependency_overrides[get_db] = override_get_db
client = TestClient(app)

VALID_PAYLOAD = {
    "system_identifier": "salesforce-prod",
    "username": "alice@example.com",
    "password": "super-secret-password",
    "label": "Salesforce production",
}


# ---------------------------------------------------------------------------
# Health
# ---------------------------------------------------------------------------
def test_health():
    r = client.get("/health")
    assert r.status_code == 200


# ---------------------------------------------------------------------------
# Create — happy path
# ---------------------------------------------------------------------------
def test_create_returns_metadata_without_password():
    r = client.post("/credentials", json=VALID_PAYLOAD)
    assert r.status_code == 201
    data = r.json()
    assert data["system_identifier"] == "salesforce-prod"
    assert "password" not in data
    assert "encrypted_password" not in data


# ---------------------------------------------------------------------------
# Create — 409 duplicate system_identifier (critical fix)
# ---------------------------------------------------------------------------
def test_create_duplicate_system_identifier_returns_409():
    """
    system_identifier must be unique.
    Submitting the same identifier twice must return 409, not silently
    create a second record.
    """
    payload = {**VALID_PAYLOAD, "system_identifier": "unique-system-409"}
    client.post("/credentials", json=payload)
    r = client.post("/credentials", json=payload)
    assert r.status_code == 409
    assert "already exists" in r.json()["detail"]


# ---------------------------------------------------------------------------
# Create — 422 validation errors
# ---------------------------------------------------------------------------
def test_create_missing_system_identifier_returns_422():
    r = client.post("/credentials", json={"username": "bob", "password": "pw"})
    assert r.status_code == 422


def test_create_invalid_system_identifier_returns_422():
    payload = {**VALID_PAYLOAD, "system_identifier": "has spaces!"}
    r = client.post("/credentials", json=payload)
    assert r.status_code == 422


def test_create_empty_password_returns_422():
    payload = {**VALID_PAYLOAD, "system_identifier": "sys-empty-pw", "password": ""}
    r = client.post("/credentials", json=payload)
    assert r.status_code == 422


# ---------------------------------------------------------------------------
# Create — 500 downstream DB failure
# ---------------------------------------------------------------------------
def test_create_db_failure_returns_500():
    with patch.object(TestSession, "commit", side_effect=SQLAlchemyError("db down")):
        r = client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "sys-500"})
    assert r.status_code == 500


