# ---------------------------------------------------------------------------
# Secret — happy path (decryption round-trip)
# ---------------------------------------------------------------------------
def test_secret_returns_decrypted_password():
    r = client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "sys-secret-test"})
    cred_id = r.json()["id"]

    secret_r = client.get(f"/credentials/{cred_id}/secret")
    assert secret_r.status_code == 200
    assert secret_r.json()["password"] == VALID_PAYLOAD["password"]


