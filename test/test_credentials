def test_list_filter_by_system():
    client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "jira-filter-test"})
    r = client.get("/credentials?system_identifier=jira-filter-test")
    assert r.status_code == 200
    assert all(item["system_identifier"] == "jira-filter-test" for item in r.json())


