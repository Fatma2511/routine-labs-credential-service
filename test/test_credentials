# Secret — 404 and 500
# ---------------------------------------------------------------------------
def test_secret_nonexistent_returns_404():
    r = client.get("/credentials/00000000-does-not-exist/secret")
    assert r.status_code == 404


def test_secret_wrong_key_returns_500():
    """Simulate key rotation failure — ciphertext encrypted with a different key."""
    from src.models import CredentialRecord
    import uuid
    wrong_fernet = Fernet(Fernet.generate_key())
    fake_ciphertext = wrong_fernet.encrypt(b"some-password").decode()

    db = TestSession()
    record = CredentialRecord(
        id=str(uuid.uuid4()),
        system_identifier="sys-wrong-key",
        username="user@example.com",
        encrypted_password=fake_ciphertext,
    )
    db.add(record)
    db.commit()
    cred_id = record.id
    db.close()

    r = client.get(f"/credentials/{cred_id}/secret")
    assert r.status_code == 500


# ---------------------------------------------------------------------------
# Plaintext never in DB
# ---------------------------------------------------------------------------
def test_password_not_in_db():
    from src.models import CredentialRecord
    db = TestSession()
    for r in db.query(CredentialRecord).all():
        assert VALID_PAYLOAD["password"] not in r.encrypted_password
        assert r.encrypted_password.startswith("gAAAAA")
    db.close()


# ---------------------------------------------------------------------------
# Update — happy path
# ---------------------------------------------------------------------------
def test_update_password():
    r = client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "sys-update"})
    cred_id = r.json()["id"]

    client.patch(f"/credentials/{cred_id}", json={"password": "new-password-789"})

    secret_r = client.get(f"/credentials/{cred_id}/secret")
    assert secret_r.json()["password"] == "new-password-789"


# ---------------------------------------------------------------------------
# Update — 400 empty body, 404 not found
# ---------------------------------------------------------------------------
def test_update_empty_body_returns_400():
    r = client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "sys-400"})
    cred_id = r.json()["id"]
    r = client.patch(f"/credentials/{cred_id}", json={})
    assert r.status_code == 400


def test_update_nonexistent_returns_404():
    r = client.patch("/credentials/00000000-does-not-exist", json={"label": "x"})
    assert r.status_code == 404


# ---------------------------------------------------------------------------
# Delete — happy path and 404
# ---------------------------------------------------------------------------
def test_delete_credential():
    r = client.post("/credentials", json={**VALID_PAYLOAD, "system_identifier": "sys-delete"})
    cred_id = r.json()["id"]

    assert client.delete(f"/credentials/{cred_id}").status_code == 204
    assert client.get(f"/credentials/{cred_id}").status_code == 404


def test_delete_nonexistent_returns_404():
    r = client.delete("/credentials/00000000-does-not-exist")
    assert r.status_code == 404
